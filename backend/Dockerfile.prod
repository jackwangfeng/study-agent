# Multi-stage prod image. Build context is the REPO ROOT (not backend/) so
# we can COPY both backend/ source and frontend/ static into one image —
# gin serves the frontend on the same origin as the API.
#
# From repo root:
#   docker buildx build --platform linux/arm64 -f backend/Dockerfile.prod -t <repo>:v1 --push .
#
# All secrets (DB URL, QWEN key) inject via -e env at runtime — image holds none.

FROM m.daocloud.io/docker.io/library/golang:1.25-alpine AS builder
WORKDIR /src
RUN apk add --no-cache git
ENV GOPROXY=https://goproxy.cn,direct

COPY backend/go.mod backend/go.sum ./
RUN go mod download

COPY backend/ ./
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /out/server ./cmd/server

# ----------------------------------------------------------------------------
FROM m.daocloud.io/docker.io/library/alpine:latest
RUN apk --no-cache add ca-certificates tzdata && \
    addgroup -S app && adduser -S app -G app

WORKDIR /app
COPY --from=builder /out/server /app/server
COPY backend/config.test.yaml /app/config.test.yaml
# Frontend baked in — same origin, no CORS, redeploy = both moves together.
COPY frontend/ /app/frontend/
RUN chown -R app:app /app

USER app
ENV GIN_MODE=release
EXPOSE 8000
ENTRYPOINT ["/app/server", "-config", "config.test"]
