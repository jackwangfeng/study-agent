# Gemini 本地开发配置模板
#
# 敏感 key 请通过环境变量注入，不要写到 yaml 里提交到 git：
#   export GEMINI_API_KEY=your-real-key
#   export VISION_API_KEY=your-real-key   # 可选，留空则复用 GEMINI_API_KEY
#
# 复制本文件为 config.gemini.yaml，按需修改非敏感字段。
# config.gemini.yaml 已在 .gitignore 中忽略。

# Gemini API URL（可选，默认使用官方地址）
gemini_api_url: "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent"

# Vision API URL（用于食物识别）
vision_api_url: "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent"

# 基础配置
project_name: "Loss Weight AI"
version: "1.0.0"
api_prefix: "/v1"
port: 8000
debug: true

# 数据库
database_url: "sqlite:///tmp/loss_weight.db"

# JWT
jwt_expire_days: 7
